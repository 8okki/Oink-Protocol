# ------------------------------------------------------------------------------
# Oink Yield Optimizer Agent - Configuration Environment Variables
# ------------------------------------------------------------------------------

# Deployed OinkVault contract address
OINK_VAULT_ADDRESS=0x18A49aEF7e31ea27E727025185F12FF0633cd6Db

# USDC Token address
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# RPC Endpoints (Testnet / Mainnet Fork RPCs)
SOURCE_RPC_URL=https://rpc.testnet.arc.network
DESTINATION_RPC_URL=https://rpc.testnet.arc.network

# Aave V4 Pool / Tokenization Spoke addresses
# (Representing source and target pools to compare rates)
AAVE_POOL_SOURCE=0x0000000000000000000000000000000000000000
AAVE_POOL_DESTINATION=0x0000000000000000000000000000000000000000

# Decision Parameters
# Minimum USD/USDC profit required to execute reallocation (configurable)
NET_PROFIT_THRESHOLD=5.0

# Yield projection period in days
PROJECTED_DAYS=30

# Simulated or actual USDC balance to rebalance
PRINCIPAL_AMOUNT=10000

# Polling Interval (in seconds)
POLLING_INTERVAL_SECONDS=300

# Google Gemini API Key for AI Agent decisions
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
